# Local server port
PORT=3000

# Use development locally. npm start sets production automatically.
NODE_ENV=development

# Replace this value in your local .env file. Never commit the real secret.
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters-long
JWT_EXPIRES_IN=8h

# Comma-separated frontend origins allowed to call the API in production.
# Same-origin requests are always accepted. Leave blank for local same-origin use.
CORS_ORIGINS=https://transitops.example.com,https://www.transitops.example.com

# Configure this when deployed behind a reverse proxy.
# Common values: false, true, or 1
TRUST_PROXY=false

# General API rate limiting.
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=240

# Stricter login and signup rate limiting.
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
